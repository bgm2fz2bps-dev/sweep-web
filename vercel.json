{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/tab/[...path].js": {
      "regions": ["syd1"]
    },
    "api/[...path].js": {
      "regions": ["syd1"]
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/check-results",
      "schedule": "*/5 * * * *"
    }
  ]
}
